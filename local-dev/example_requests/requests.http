POST http://localhost:8082/api/v1/responses
Content-Type: application/json
Authorization: Bearer <your-dev-token-here>

{
  "model": "gpt-5-mini",
  "input": [
    {
      "role": "system",
      "content": [
        {
          "type": "input_text",
          "text": "You are a concise helper."
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "Confirm the corrected token type for responses requests."
        }
      ]
    }
  ]
}